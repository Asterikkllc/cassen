# Copy to .env and fill in real values. .env is gitignored.

# --- Nexar (Octopart) — multi-distributor aggregator (Digi-Key, Mouser, LCSC, …) ---
# https://nexar.com → register, get client ID + secret. Used as the primary
# search source.
NEXAR_CLIENT_ID=
NEXAR_CLIENT_SECRET=

# --- Mouser ---
# https://www.mouser.com/api-search/ → request a key. Used as a fallback
# search source after Nexar.
MOUSER_API_KEY=

# --- Digi-Key (production) ---
# https://developer.digikey.com → create an app → client_credentials flow.
# Used as a tertiary lookup for direct part details.
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
