# Copy to .env.local and fill in real values. Never commit .env.local.

# --- Supabase (Phase 3) ---
# Project Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- SMTP (Phase 4) ---
# Any SMTP provider — Postmark, SendGrid, Mailgun, AWS SES, Gmail app password, your own server, etc.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
FROM_EMAIL=hello@cassen.ai
FROM_NAME=Cassen

# --- Site URL (Phase 13) ---
NEXT_PUBLIC_SITE_URL=https://cassen.ai

# --- Analytics (Phase 11) ---
# Project Token from https://app.posthog.com/project/settings (project API key)
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Admin dashboard (Phase 12) ---
ADMIN_EMAIL=you@cassen.ai

# --- Rate limiting (Upstash Redis) ---
# Required in production. Sign up at https://console.upstash.com/, create a
# Redis database, copy the REST URL and TOKEN. Without these, signup and
# admin-login fall back to an in-memory limiter that resets on every cold
# start and isn't shared across instances — fine for dev, NOT for prod.
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-token
