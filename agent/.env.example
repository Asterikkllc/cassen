# Anthropic — the LLM behind every node in the agent graph.
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# Supabase — same project the app/ surface uses. The agent reads/writes
# the project_messages thread directly so its events show up on refresh.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# Shared secret the app/ proxy sends as a bearer token. Must match the
# AGENT_SHARED_SECRET in app/.env.local. Required when the service is
# deployed; can be empty in local dev (server warns + allows all).
AGENT_SHARED_SECRET=

# Bind address. 127.0.0.1 locally; 0.0.0.0 when containerized.
AGENT_HOST=127.0.0.1
AGENT_PORT=8001

# Models. Sonnet 4.6 for the planner — fast enough for an interactive
# chat surface, strong enough for cross-domain reasoning. Haiku 4.5 is
# tagged for tool-loop research nodes that land in a later slice.
PLANNER_MODEL=claude-sonnet-4-6
RESEARCH_MODEL=claude-haiku-4-5
