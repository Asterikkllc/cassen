ANTHROPIC_API_KEY=sk-ant-api03-xxx

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_SECRET_KEY=sk-lf-xxx
LANGFUSE_HOST=https://cloud.langfuse.com

# Shared secret used to authenticate calls from app/ to this service.
# Must match AGENT_SHARED_SECRET in app/.env.local.
AGENT_SHARED_SECRET=generate-a-random-string-here

# Bind address. 127.0.0.1 in dev; 0.0.0.0 in containerized prod.
AGENT_HOST=127.0.0.1
AGENT_PORT=8001

# Trigger.dev (Phase 5b — not used yet by this service)
TRIGGER_PROJECT_REF=proj_xxx
TRIGGER_SECRET_KEY=tr_dev_xxx

# --- MCP knowledge packs (Phase 6b) ---
# Absolute path to the cassen-electronics MCP server source. The agent
# spawns it as a subprocess via stdio when planner output flags
# "electronics" as a relevant domain.
MCP_ELECTRONICS_PATH=C:\Users\HP\Cassen\mcp-electronics
# Command used to launch each MCP server subprocess. uv is the default
# because the MCP servers are uv-managed Python projects.
UV_COMMAND=uv
