# Bearer secret used to authenticate calls into this service. Must match
# whatever caller (agent, app) sets when forwarding a request.
CAD_SHARED_SECRET=generate-a-random-string-here

# Bind address. 127.0.0.1 in dev; 0.0.0.0 in containerized prod.
CAD_HOST=127.0.0.1
CAD_PORT=8002

# Hard cap on uploaded STEP size. Anything larger is rejected before
# touching the converter.
MAX_STEP_BYTES=52428800
