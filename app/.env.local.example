# Copy to .env.local and fill in real values. Never commit .env.local.

# --- Clerk (Phase 2) ---
# https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Routes Clerk redirects through. These match the pages shipped in app/src/app/.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/projects
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/projects

# --- Supabase (Phase 3) — must be a separate Supabase project from the landing waitlist ---
# Create a new project at https://supabase.com/dashboard. Copy from Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Cassen Agent (Phase 5) ---
# URL of the Python LangGraph FastAPI service. In dev: http://127.0.0.1:8001.
# In prod: wherever you deploy the agent (Modal, Fly, Railway, ECS, etc.).
AGENT_BASE_URL=http://127.0.0.1:8001
# Shared bearer secret used to authenticate calls from this app to the agent.
# Identical value must be set as AGENT_SHARED_SECRET in agent/.env. Generate
# with `openssl rand -hex 32` (or any random 32+ char string).
AGENT_SHARED_SECRET=generate-a-random-string-here

# --- Site URL ---
# In production this is the public URL of the v1 app, e.g. https://app.cassen.ai
NEXT_PUBLIC_SITE_URL=https://app.cassen.ai
