# --- Anthropic (reasoning core) -------------------------------------------
# Used by /api/chat as a direct LLM call until the FastAPI agent service
# lands. Provision at https://console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# --- Clerk (consumer auth) ------------------------------------------------
# Provision at https://dashboard.clerk.com. The publishable key ships to
# the browser; the secret stays server-side.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# --- Supabase (Postgres + Storage + pgvector) -----------------------------
# Provision at https://supabase.com. NEXT_PUBLIC_* keys are browser-safe;
# the service-role key is server-side ONLY (bypasses RLS).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# --- Observability (optional in dev) --------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Agent service (Phase 1+, not yet deployed) ---------------------------
# Populated once the FastAPI agent lands. Leave blank in scaffold; /api/chat
# falls back to direct Anthropic calls when AGENT_BASE_URL is empty.
AGENT_BASE_URL=
AGENT_SHARED_SECRET=
